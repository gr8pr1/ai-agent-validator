# AI Agent Validator — agent configuration example.
# Copy to config.yaml and edit:  cp config.yaml.example config.yaml
# Full reference: config.md

log_level: info   # debug|info|warn|error
log_format: text  # text|json
log_file: ""      # optional; duplicates slog (startup, debug, snapshots) to this path

# Mode A: controlled-spawn enrollment. Any process whose cgroup-v2 path contains
# one of these substrings is enrolled as an AI agent. Launch your agents under a
# dedicated slice (e.g. systemd Slice=ai-agents.slice) to use this.
mode_a:
  enabled: true
  cgroup_contains:
    - "ai-agents.slice"
  default_agent_id: "agent"

# Mode B: exec-time fingerprint enrollment against the fingerprint set.
mode_b:
  enabled: true
  fingerprints_path: "fingerprints.yaml"

# P0.5: observe-only action capture for enrolled agents (connect/open/unlink/rename).
actions:
  enabled: true
  capture: [connect, open, unlink, rename]
  open_writes_only: true   # false while testing read visibility (noisy)

report:
  format: text         # text|json
  audit_log: ""          # append-only JSONL path; empty disables
  all_events: false      # also report untagged exec events (very noisy)
  snapshot_sec: 30       # periodic snapshot interval in seconds; 0 disables

debug:
  enabled: false
  http_addr: "127.0.0.1:9230"

# P2: shadow-mode policy evaluation (log-only; no enforcement).
policy:
  enabled: false
  store_path: "./policy-store"
  pub_key_path: "policy.pub"
  reload_sec: 15
  scope: ""   # optional override for agent_scope matching
